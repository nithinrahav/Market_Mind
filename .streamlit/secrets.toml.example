# Copy this file to secrets.toml and fill in your real keys.
# secrets.toml is gitignored — never commit it.

ANTHROPIC_API_KEY = "sk-ant-..."

ETRADE_CONSUMER_KEY    = "your_etrade_consumer_key"
ETRADE_CONSUMER_SECRET = "your_etrade_consumer_secret"
ETRADE_ENV             = "sandbox"   # or "live"

NEWS_API_KEY     = "your_newsapi_key"
ALPHA_VANTAGE_KEY = "your_alphavantage_key"

CACHE_TTL_SECONDS = "300"
LOG_LEVEL         = "INFO"
